{
  "cli": {
    "version": ">= 18.0.1",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "image": "sdk-55"
      },
      "env": {
        "EXPO_PUBLIC_USE_TEST_ADS": "true"
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "image": "sdk-55"
      },
      "env": {
        "EXPO_PUBLIC_USE_TEST_ADS": "true"
      }
    },
    "production": {
      "autoIncrement": true,
      "ios": {
        "image": "sdk-55"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
